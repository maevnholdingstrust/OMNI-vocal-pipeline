def init_benchmark_manifest() -> str:
    manifest_path = f"{BENCHMARK_DIR}/benchmark_manifest.json"
    if os.path.exists(manifest_path):
        return manifest_path

    seed_manifest = {
        "version": "1.0.0",
        "description": "Locked benchmark set for quality regression.",
        "tracks": [
            {
                "id": "track_001",
                "path": "/content/benchmark_input/track_001.wav",
                "genre": "pop",
                "tempo_bpm": 120,
                "vocal_style": "belt",
                "vocal_gender": "female",
                "mix_density": "dense",
                "status": "replace_with_real_track",
            }
        ],
    }
    with open(manifest_path, "w", encoding="utf-8") as f:
        json.dump(seed_manifest, f, indent=2)
    return manifest_path


def utc_timestamp() -> str:
    return dt.datetime.now(dt.timezone.utc).isoformat()


def dbfs_from_peak(peak: float) -> float:
    return 20.0 * np.log10(max(peak, 1e-9))


def estimate_lufs_proxy_db(audio: np.ndarray) -> float:
    # Lightweight RMS-based loudness proxy for release-gate automation.
    rms = np.sqrt(np.mean(np.square(audio), axis=0)).mean() if audio.ndim > 1 else np.sqrt(np.mean(np.square(audio)))
    return 20.0 * np.log10(max(float(rms), 1e-9))


def true_peak_dbfs(audio: np.ndarray) -> float:
    peak = float(np.max(np.abs(audio)))
    return dbfs_from_peak(peak)


def clipping_ratio(audio: np.ndarray, threshold: float = 0.999) -> float:
    samples_over = np.sum(np.abs(audio) >= threshold)
    return float(samples_over / max(audio.size, 1))


def stereo_correlation(audio: np.ndarray) -> float:
    if audio.ndim != 2 or audio.shape[1] < 2:
        return 1.0
    left = audio[:, 0]
    right = audio[:, 1]
    if np.std(left) < 1e-9 or np.std(right) < 1e-9:
        return 1.0
    return float(np.corrcoef(left, right)[0, 1])


def speech_band_intelligibility(audio: np.ndarray, sr: int) -> float:
    # With always_2d=True, soundfile returns (samples, channels); axis=1 averages channels.
    mono = audio.mean(axis=1) if audio.ndim == 2 else audio
    spectrum = np.abs(np.fft.rfft(mono))
    freqs = np.fft.rfftfreq(len(mono), 1.0 / sr)
    speech_mask = (freqs >= 150) & (freqs <= 4000)
    total_energy = float(np.sum(spectrum) + 1e-9)
    speech_energy = float(np.sum(spectrum[speech_mask]))
    return speech_energy / total_energy


def artifact_score(audio: np.ndarray, sr: int) -> float:
    # With always_2d=True, soundfile returns (samples, channels); axis=1 averages channels.
    mono = audio.mean(axis=1) if audio.ndim == 2 else audio
    spectrum = np.abs(np.fft.rfft(mono))
    freqs = np.fft.rfftfreq(len(mono), 1.0 / sr)
    harsh = np.sum(spectrum[(freqs >= 9000) & (freqs <= 18000)])
    mids = np.sum(spectrum[(freqs >= 500) & (freqs <= 5000)]) + 1e-9
    return float(np.clip(harsh / mids, 0.0, 1.0))


def estimate_snr_db(audio: np.ndarray) -> float:
    # With always_2d=True, soundfile returns (samples, channels); axis=1 averages channels.
    mono = audio.mean(axis=1) if audio.ndim == 2 else audio
    signal = np.percentile(np.abs(mono), 90) + 1e-9
    noise = np.percentile(np.abs(mono), 20) + 1e-9
    return float(20.0 * np.log10(signal / noise))


def audio_sha256(path: str) -> str:
    digest = hashlib.sha256()
    with open(path, "rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            digest.update(chunk)
    return digest.hexdigest()


def collect_metrics(path: str) -> Dict[str, float]:
    audio, sr = sf.read(path, always_2d=True)
    audio = np.asarray(audio, dtype=np.float32)
    return {
        "lufs": estimate_lufs_proxy_db(audio),
        "true_peak_dbfs": true_peak_dbfs(audio),
        "snr_db": estimate_snr_db(audio),
        "intelligibility": speech_band_intelligibility(audio, sr),
        "artifact_score": artifact_score(audio, sr),
        "stereo_corr": stereo_correlation(audio),
        "clipping_ratio": clipping_ratio(audio),
    }


def evaluate_release_gate(metrics: Dict[str, float], preset_name: str, listener_preference_score: Optional[float]) -> Tuple[bool, List[str]]:
    limits = PRESET_CONSTRAINTS[preset_name]
    failures: List[str] = []

    if abs(metrics["lufs"] - limits["target_lufs"]) > limits["lufs_tolerance"]:
        failures.append("lufs_out_of_range")
    if metrics["true_peak_dbfs"] > limits["max_true_peak_dbfs"]:
        failures.append("true_peak_too_high")
    if metrics["snr_db"] < limits["min_snr_db"]:
        failures.append("snr_below_threshold")
    if metrics["intelligibility"] < limits["min_intelligibility"]:
        failures.append("intelligibility_below_threshold")
    if metrics["artifact_score"] > limits["max_artifact_score"]:
        failures.append("artifact_score_too_high")
    if metrics["stereo_corr"] < limits["stereo_corr_min"] or metrics["stereo_corr"] > limits["stereo_corr_max"]:
        failures.append("stereo_correlation_out_of_range")
    if metrics["clipping_ratio"] > limits["max_clipping_ratio"]:
        failures.append("clipping_detected")
    if listener_preference_score is None:
        failures.append("listener_preference_missing")
    elif listener_preference_score < limits["min_listener_pref"]:
        failures.append("listener_preference_below_threshold")

    return len(failures) == 0, failures


def write_qa_report(track_id: str, preset_name: str, metrics: Dict[str, float], passed: bool, failures: List[str]) -> str:
    report_path = f"{QA_REPORT_DIR}/{track_id}_qa.json"
    payload = {
        "track_id": track_id,
        "preset": preset_name,
        "timestamp_utc": utc_timestamp(),
        "metrics": metrics,
        "passed": passed,
        "failures": failures,
    }
    with open(report_path, "w", encoding="utf-8") as f:
        json.dump(payload, f, indent=2)
    return report_path


def append_run_history(track_id: str, preset_name: str, input_path: str, output_path: str, metrics: Dict[str, float], passed: bool) -> None:
    row = {
        "timestamp_utc": utc_timestamp(),
        "track_id": track_id,
        "preset": preset_name,
        "input_path": input_path,
        "output_path": output_path,
        "input_sha256": audio_sha256(input_path),
        "output_sha256": audio_sha256(output_path),
        "metrics": metrics,
        "passed_release_gate": passed,
        "model_name": "maevn1",
        "f0_method": "rmvpe",
    }
    with open(RUN_HISTORY_PATH, "a", encoding="utf-8") as f:
        f.write(json.dumps(row) + "\n")


def build_blind_ab_packet(track_id: str, candidate_path: str, baseline_path: str) -> str:
    out_dir = f"{AB_TEST_DIR}/{track_id}"
    os.makedirs(out_dir, exist_ok=True)
    pairs = [("A", candidate_path), ("B", baseline_path)]
    random.shuffle(pairs)
    for label, src in pairs:
        shutil.copy2(src, f"{out_dir}/{label}.wav")

    rubric_path = f"{out_dir}/rubric.csv"
    with open(rubric_path, "w", newline="", encoding="utf-8") as csv_file:
        writer = csv.writer(csv_file)
        writer.writerow(["rater_id", "track_id", "preferred_version", "vocal_clarity_1_10", "artifact_control_1_10", "mix_translation_1_10", "notes"])
    return out_dir


def read_listener_preference_score(track_id: str) -> Optional[float]:
    summary_path = f"{AB_TEST_DIR}/{track_id}/listener_summary.json"
    if not os.path.exists(summary_path):
        return None
    try:
        with open(summary_path, "r", encoding="utf-8") as f:
            payload = json.load(f)
        return float(payload.get("mean_preference_score"))
    except (TypeError, ValueError, json.JSONDecodeError):
        return None


def weekly_regression_report(output_path: str = f"{QUALITY_DIR}/weekly_regression_report.json") -> str:
    if not os.path.exists(RUN_HISTORY_PATH):
        with open(output_path, "w", encoding="utf-8") as f:
            json.dump({"status": "no_history"}, f, indent=2)
        return output_path

    rows = []
    with open(RUN_HISTORY_PATH, "r", encoding="utf-8") as f:
        for line in f:
            if line.strip():
                rows.append(json.loads(line))

    by_preset: Dict[str, List[float]] = {}
    pass_rates: Dict[str, float] = {}
    for row in rows:
        preset = row["preset"]
        by_preset.setdefault(preset, []).append(row["metrics"]["artifact_score"])
        pass_rates.setdefault(preset, 0.0)
        pass_rates[preset] += 1.0 if row["passed_release_gate"] else 0.0

    report = {"generated_utc": utc_timestamp(), "presets": {}}
    for preset, artifact_scores in by_preset.items():
        n = len(artifact_scores)
        report["presets"][preset] = {
            "runs": n,
            "mean_artifact_score": float(np.mean(artifact_scores)),
            "release_gate_pass_rate": pass_rates[preset] / max(n, 1),
        }

    with open(output_path, "w", encoding="utf-8") as f:
        json.dump(report, f, indent=2)
    return output_path


