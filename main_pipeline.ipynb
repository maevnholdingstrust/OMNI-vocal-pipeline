Python# @title 3. Process new_render_slot (Lead/Backup + RVC Clone)
import os
from audio_separator.separator import Separator
from pydub import AudioSegment

render_slot = "/content/new_render_slot"
os.makedirs(render_slot, exist_ok=True)
os.makedirs("/content/isolated", exist_ok=True)

audio_files = glob.glob(f"{render_slot}/*.wav") + glob.glob(f"{render_slot}/*.mp3")

if not audio_files:
    print("Upload songs to new_render_slot folder (left sidebar)")
    uploaded = files.upload()
    for fname in uploaded:
        !mv "{fname}" "{render_slot}/"

for path in audio_files:
    base = os.path.splitext(os.path.basename(path))[0]
    print(f"\nProcessing: {base}")
    
    # Vocals isolation + Lead split (efficient models)
    sep = Separator(output_dir="/content/isolated", model_name="htdemucs_ft", device="cuda", segment_size=256)
    sep.separate(path)
    
    # Simple lead extraction (adjust if needed)
    lead_path = f"{render_slot}/guide_{base}.wav"
    # ... (copy best vocal file here - shortened for clarity)
    
    # RVC Clone
    out_path = f"{render_slot}/maevn1_cloned_{base}.wav"
    !python tools/cmd/infer_cli.py --model_name "maevn1" --input_path "{lead_path}" --opt_path "{out_path}" --f0_method "rmvpe" --index_rate 0.75 --device "cuda:0"
    
    print(f"✅ Cloned: maevn1_cloned_{base}.wav")
