# Cell 4: Process new_render_slot (Lead/Backup + RVC Clone)
# @title 4. Process new_render_slot (Lead/Backup + RVC Clone)
from audio_separator.separator import Separator
from pydub import AudioSegment
from pydub.effects import compress_dynamic_range

render_slot = "/content/new_render_slot"
isolated_dir = "/content/isolated"
os.makedirs(render_slot, exist_ok=True)
os.makedirs(isolated_dir, exist_ok=True)


def best_vocal_stem(base_name: str) -> str:
    candidates = glob.glob(f"{isolated_dir}/{base_name}*vocals*.wav")
    if not candidates:
        raise FileNotFoundError(f"No vocal stem found for {base_name}")
    return max(candidates, key=lambda p: os.path.getsize(p))


def clean_vocal(vocal_path: str, out_path: str) -> str:
    seg = AudioSegment.from_file(vocal_path)
    # Conservative vocal leveling to stabilize RVC conditioning without flattening transients
    # using threshold=-24 dBFS, ratio=2:1, attack=5 (ms), and release=50 (ms).
    seg = compress_dynamic_range(seg, threshold=-24.0, ratio=2.0, attack=5, release=50)
    # Remove low rumble (<80Hz) and extreme top-end noise (>17kHz) before inference.
    seg = seg.high_pass_filter(80).low_pass_filter(17000)
    seg.export(out_path, format="wav")
    return out_path


audio_files = sorted(glob.glob(f"{render_slot}/*.wav") + glob.glob(f"{render_slot}/*.mp3"))
if not audio_files and files:
    print("Upload songs to new_render_slot folder (left sidebar)")
    uploaded_audio = files.upload()
    for fname in uploaded_audio:
        shutil.move(fname, f"{render_slot}/{fname}")
    audio_files = sorted(glob.glob(f"{render_slot}/*.wav") + glob.glob(f"{render_slot}/*.mp3"))

for path in audio_files:
    base = os.path.splitext(os.path.basename(path))[0]
    print(f"\nProcessing: {base}")

    # Stronger stem separation (quality-first default)
    sep = Separator(output_dir=isolated_dir, model_name="htdemucs_ft", device="cuda", segment_size=256)
    sep.separate(path)

    # Cleaner vocal conditioning before RVC
    raw_vocal = best_vocal_stem(base)
    lead_path = f"{render_slot}/guide_{base}.wav"
    clean_vocal(raw_vocal, lead_path)

    # RVC clone
    out_path = f"{render_slot}/maevn1_cloned_{base}.wav"
    run_cmd(
        [
            "python",
            "tools/cmd/infer_cli.py",
            "--model_name",
            "maevn1",
            "--input_path",
            lead_path,
            "--opt_path",
            out_path,
            "--f0_method",
            "rmvpe",
            "--index_rate",
            "0.75",
            "--device",
            "cuda:0",
        ]
    )
    print(f"✅ Cloned: maevn1_cloned_{base}.wav")


# Cell 5: Reference-aware Mastering + Release Gates
# @title 5. Mastering + QA Gate (Blocks Export on Failure)
import matchering as mg

mastered_slot = "/content/new_render_slot/mastered"
baseline_slot = "/content/new_render_slot/baseline"
os.makedirs(mastered_slot, exist_ok=True)
os.makedirs(baseline_slot, exist_ok=True)

preset_name = "streaming clean"  # @param ["streaming clean", "radio loud", "cinematic wide"]
constraints = PRESET_CONSTRAINTS[preset_name]
cloned = sorted(glob.glob(f"{render_slot}/maevn1_cloned_*.wav"))
released_files: List[str] = []

for f in cloned:
    base = os.path.basename(f).replace("maevn1_cloned_", "").replace(".wav", "")
    out = f"{mastered_slot}/maevn1_mastered_{base}.wav"
    baseline = f"{baseline_slot}/baseline_{base}.wav"
    if not os.path.exists(baseline):
        shutil.copy2(f, baseline)

    print(f"Mastering {base} with preset '{preset_name}'...")
    mg.process(target=f, results=[mg.Result(out)], loudness=constraints["target_lufs"])

    metrics = collect_metrics(out)
    listener_preference_score = read_listener_preference_score(base)
    passed, failures = evaluate_release_gate(metrics, preset_name, listener_preference_score=listener_preference_score)
    report_path = write_qa_report(base, preset_name, metrics, passed, failures)
    append_run_history(base, preset_name, f, out, metrics, passed)
    build_blind_ab_packet(base, out, baseline)

    if not passed:
        print(f"❌ QA gate failed for {base}: {failures}")
        print(f"   QA report: {report_path}")
        continue

    released_files.append(out)
    print(f"✅ Release gate passed for {base}")

weekly_path = weekly_regression_report()
print(f"📈 Weekly regression summary: {weekly_path}")
print(f"✅ Mastering complete. Released tracks: {len(released_files)}/{len(cloned)}")


# Cell 6: Download Released Files
# @title 6. Download Released Files
if files:
    for f in released_files:
        files.download(f)
print("✅ Download complete!")
